---
import '../styles/global.css';
import '../styles/styles.css'; // Estilos da biblioteca
import Header from '../components/Header.astro';
import Biblioteca from '../components/Biblioteca';
import ChamadasAbertas from '../components/library/ChamadasAbertas';
---

<!DOCTYPE html>
<html lang="pt-BR" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Biblioteca | Editora Poisson</title>
    <meta name="description" content="Explore a Biblioteca Virtual da Editora Poisson. Mais de 1.200 títulos acadêmicos gratuitos em ciências exatas, humanas, saúde, engenharias e mais.">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200;300;400;700&family=Playfair+Display:ital,wght@0,900;1,900&display=swap" rel="stylesheet">
    <style is:global>
        body, html {
            background-color: var(--background) !important;
            color: var(--foreground) !important;
        }
    </style>
</head>
<body>
    <Header />

    <!-- Componente React da Biblioteca -->
    <main class="pt-32">
        <Biblioteca client:load />
    </main>

    <!-- Componente React das Chamadas Abertas -->
    <ChamadasAbertas client:load />

    <style is:global>
        .serif { font-family: 'Playfair Display', serif; }

        @keyframes marquee {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }

        .marquee-container {
            overflow: hidden;
            user-select: none;
            display: flex;
            width: 100%;
        }

        .marquee-track {
            display: flex;
            width: max-content;
            animation: marquee 40s linear infinite;
        }

        .marquee-track:hover {
            animation-play-state: paused;
        }

        .book-item {
            width: 160px;
            height: 240px;
            flex-shrink: 0;
            margin: 0 0.75rem;
            position: relative;
            border-radius: 4px 8px 8px 4px;
            overflow: hidden;
            box-shadow: 5px 5px 15px rgba(0,0,0,0.4);
            transition: all 0.5s cubic-bezier(0.2, 0, 0.2, 1);
            background: #1a1a1a;
            cursor: pointer;
        }

        .book-item::after {
            content: "";
            position: absolute;
            left: 0;
            top: 0;
            width: 6px;
            height: 100%;
            background: linear-gradient(90deg, rgba(0,0,0,0.4) 0%, rgba(255,255,255,0.1) 50%, transparent 100%);
            z-index: 5;
        }

        .book-item:hover {
            transform: scale(1.05) translateY(-10px);
            box-shadow: 15px 15px 30px rgba(0,0,0,0.6);
            z-index: 50;
        }

        .book-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.8s ease;
        }

        .book-item:hover img {
            transform: scale(1.1);
        }
    </style>
</body>
</html>
