    <script is:inline defer src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    <script is:inline defer src={`/js/teste.js?v=${version}`}></script>

    <!-- Popup -->
    <script is:inline>
      (function() {
        const isLocal = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1';
        const API_BASE = isLocal ? 'http://localhost:3001/api/public' : 'https://individual.poisson.com.br/api/public';
        const popupPromise = fetch(`${API_BASE}/popup`).then(res => res.ok ? res.json() : null).catch(() => null);

        async function initPopup() {
          try {
            const config = await popupPromise;
            if (!config || !config.enabled) return;
            const now = new Date();
            if (config.scheduling) {
              if (config.scheduling.startDateTime && now < new Date(config.scheduling.startDateTime)) return;
              if (config.scheduling.endDateTime && now > new Date(config.scheduling.endDateTime)) return;
            }
            const triggers = config.triggers || {};
            if (!triggers.alwaysShow) {
              const sc = parseInt(sessionStorage.getItem('poisson_popup_session_count') || '0', 10);
              if (sc >= (triggers.maxDisplayCount || 1)) return;
              const du = localStorage.getItem('poisson_popup_dismissed_until');
              if (du && now.getTime() < parseInt(du, 10)) return;
            }
            if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', () => setupTriggers(config));
            else setupTriggers(config);
          } catch {}
        }

        let popupTriggered = false, timerId = null;

        function setupTriggers(config) {
          const triggers = config.triggers || {};
          function handleScroll() {
            const dh = document.documentElement.scrollHeight - window.innerHeight;
            if (dh > 0 && (window.scrollY / dh) * 100 >= (triggers.scrollDepth || 30)) triggerPopup(config);
          }
          function handleMouseLeave(e) { if (e.clientY <= 0) triggerPopup(config); }
          timerId = setTimeout(() => triggerPopup(config), (typeof triggers.delay === 'number' ? triggers.delay : 5) * 1000);
          if (typeof triggers.scrollDepth === 'number') window.addEventListener('scroll', handleScroll, { passive: true });
          if (triggers.exitIntent) document.addEventListener('mouseleave', handleMouseLeave);
          window._poissonPopupCleanup = function() {
            window.removeEventListener('scroll', handleScroll);
            document.removeEventListener('mouseleave', handleMouseLeave);
            if (timerId) clearTimeout(timerId);
          };
        }

        function triggerPopup(config) {
          if (popupTriggered) return;
          popupTriggered = true;
          if (window._poissonPopupCleanup) window._poissonPopupCleanup();
          renderPopup(config);
        }

        function renderPopup(config) {
          const s = config.styling || {}, c = config.content || {};
          const st = document.createElement('style');
          st.innerHTML = `#pp-bd{position:fixed;inset:0;z-index:99999;display:flex;align-items:center;justify-content:center;padding:1rem;background:rgba(0,0,0,${s.overlayOpacity||0.65});backdrop-filter:blur(4px);transition:opacity .3s;opacity:0}#pp-md{background:${s.backgroundColor||'#1e293b'};color:${s.textColor||'#fff'};border-radius:${s.borderRadius||16}px;max-width:${s.width||520}px;width:100%;max-height:90vh;overflow-y:auto;box-shadow:0 25px 50px -12px rgba(0,0,0,.5);display:flex;flex-direction:column;position:relative;transition:transform .3s cubic-bezier(.34,1.56,.64,1),opacity .3s;transform:scale(.95);opacity:0}#pp-cl{position:absolute;top:.75rem;right:.75rem;z-index:10;border:none;background:rgba(0,0,0,.2);color:${s.textColor||'#fff'};width:1.75rem;height:1.75rem;border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:1.1rem;line-height:1}#pp-ic{width:100%;aspect-ratio:2/1;overflow:hidden;background:#0f172a}#pp-ic img{width:100%;height:100%;object-fit:cover}#pp-cn{padding:1.5rem;display:flex;flex-direction:column;flex-grow:1}#pp-ti{font-family:'Plus Jakarta Sans',sans-serif;font-size:1.25rem;font-weight:800;margin:0 0 .75rem}#pp-bo{font-size:.875rem;line-height:1.5;opacity:.9;margin-bottom:1.5rem;font-weight:300}#pp-ct{display:block;width:100%;padding:.875rem 1rem;background:${s.buttonBgColor||'#ff3c00'};color:${s.buttonTextColor||'#fff'};text-align:center;text-transform:uppercase;font-weight:800;font-size:.75rem;letter-spacing:.1em;border-radius:${Math.min(s.borderRadius||16,12)}px;text-decoration:none}@media(max-width:640px){#pp-md{max-width:100%;max-height:85vh}}`;
          document.head.appendChild(st);

          const bd = document.createElement('div'); bd.id = 'pp-bd';
          const md = document.createElement('div'); md.id = 'pp-md';

          function close() {
            const t = config.triggers || {};
            if (!t.alwaysShow) {
              const n = parseInt(sessionStorage.getItem('poisson_popup_session_count')||'0',10);
              sessionStorage.setItem('poisson_popup_session_count',(n+1).toString());
              if (typeof t.frequencyCapDays==='number'&&t.frequencyCapDays>0)
                localStorage.setItem('poisson_popup_dismissed_until',(Date.now()+t.frequencyCapDays*86400000).toString());
            }
            bd.style.opacity='0'; md.style.transform='scale(.95)'; md.style.opacity='0';
            setTimeout(()=>{bd.remove();st.remove();},300);
          }

          if (s.closeOnEsc) { const h=(e)=>{if(e.key==='Escape'){document.removeEventListener('keydown',h);close();}}; document.addEventListener('keydown',h); }
          bd.addEventListener('click',(e)=>{ if(e.target===bd) close(); });
          if (s.showCloseButton) { const b=document.createElement('button');b.id='pp-cl';b.innerHTML='&times;';b.onclick=close;md.appendChild(b); }

          if (c.imageUrl) { const ic=document.createElement('div');ic.id='pp-ic';const img=document.createElement('img');img.src=c.imageUrl;img.alt=c.title||'';ic.appendChild(img);md.appendChild(ic); }
          const cn=document.createElement('div');cn.id='pp-cn';
          const ti=document.createElement('h3');ti.id='pp-ti';ti.innerText=c.title||'';cn.appendChild(ti);
          const bo=document.createElement('div');bo.id='pp-bo';bo.innerHTML=c.body||'';cn.appendChild(bo);
          if(c.buttonText){const ct=document.createElement('a');ct.id='pp-ct';ct.href=c.buttonUrl||'#';ct.innerText=c.buttonText;ct.onclick=close;cn.appendChild(ct);}
          md.appendChild(cn); bd.appendChild(md); document.body.appendChild(bd);
          requestAnimationFrame(()=>{ bd.style.opacity='1'; md.style.transform='scale(1)'; md.style.opacity='1'; });
        }

        initPopup();
      })();
    </script>

    <SiteFooter />
</body>
</html>
