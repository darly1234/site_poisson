---
import '../styles/global.css';
import '../styles/home.css';
import Header from '../components/Header.astro';
import { OrbitalCarousel } from '../components/OrbitalCarousel';
import SiteFooter from '../components/SiteFooter.astro';
import versionData from '../data/version.json';

const version = versionData.version;

// Pré-carrega imagem do popup para evitar LCP tardio
let popupImageUrl: string | null = null;
try {
  const r = await fetch('https://individual.poisson.com.br/api/public/popup');
  if (r.ok) {
    const p = await r.json();
    if (p?.enabled && p?.content?.imageUrl) popupImageUrl = p.content.imageUrl;
  }
} catch {}
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <script is:inline>
      localStorage.removeItem('theme');
      document.documentElement.setAttribute('data-theme','dark');
    </script>
    <style is:global>
      #theme-toggle-btn, #theme-toggle-btn-mobile { display: none !important; }
    </style>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editora Poisson | O Fio do Conhecimento</title>
    <meta name="description" content="Editora Poisson — mais de 1.200 títulos científicos em acesso aberto, com ISBN, DOI e ficha catalográfica. Publique sua pesquisa com a gente.">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    {popupImageUrl && <link rel="preload" as="image" href={popupImageUrl} fetchpriority="high" />}

    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200;300;400;700&family=Playfair+Display:ital,wght@0,900;1,900&family=DM+Serif+Display:ital@0;1&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200;300;400;700&family=Playfair+Display:ital,wght@0,900;1,900&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet"></noscript>
</head>
<body>

    <Header />

    <!-- PARTE 1: SCROLL HORIZONTAL -->
    <div class="horizontal-wrapper">
        <div class="horizontal-container" id="master-scroll">
            
            <!-- SVG Dinmico Horizontal Reajustado para 480vw -->
            <svg id="horizontal-vine-svg" viewBox="0 0 4800 1000" preserveAspectRatio="none" class="opacity-0">
                <defs>
                    <filter id="hand-drawn-h" x="-5%" y="-5%" width="110%" height="110%">
                        <feTurbulence type="turbulence" baseFrequency="0.012 0.008" numOctaves="4" seed="7" result="noise"/>
                        <feDisplacementMap in="SourceGraphic" in2="noise" scale="4" xChannelSelector="R" yChannelSelector="G"/>
                    </filter>
                </defs>
                <path id="h-vine" class="thread-path" d="M 50,500 C 350,250 650,750 1000,500 S 1700,200 2400,500 S 3100,800 3800,500 C 4050,200 4300,400 4300,1000"
                    style="filter: url(#hand-drawn-h);" />
                <path id="h-vine-reverse" class="thread-path" d="M 50,500 C 350,250 650,750 1000,500 S 1700,200 2400,500 S 3100,800 3800,500 C 4050,200 4300,400 4300,1000"
                    style="filter: url(#hand-drawn-h); display:none;" />
                <circle class="node" cx="3800" cy="500" r="10" />
                <circle class="node" cx="4300" cy="1000" r="10" />
            </svg>
            
            <!-- SVG para a Seta (sem esticamento) -->
            <svg id="h-arrow-svg" style="position:absolute; top:0; left:0; width:480vw; height:100vh; overflow:visible; pointer-events:none; z-index: 200;">
                <g id="h-arrow-tip" style="display:none;">
                    <path d="M -55,-13 L 0,0 L -55,13" fill="none" stroke="#ff3c00" stroke-width="8" stroke-linecap="round" stroke-linejoin="round" id="h-arrow-path"/>
                </g>
            </svg>

            <!-- PAINEL 01 -->
            <section class="panel">

                <div class="w-full relative z-10">
                    <h1 class="text-5xl md:text-[10vw] serif-extra leading-none mb-4 mt-[14vh] md:mt-[16vh] xl:mt-[10vh] 2xl:mt-[8vh]" id="premium-title">
                        <div class="line-wrap"><span class="kinetic-text">A</span></div>
                        <div class="line-wrap"><span class="kinetic-text">CIÊNCIA</span></div>
                        <br>
                        <div class="heartbeat-pulse mt-2">
                            <div class="line-wrap">
                                <span class="kinetic-text italic text-zinc-400/50">
                                    É VIVA
                                </span>
                            </div>
                        </div>
                    </h1>
                    
                    <div class="max-w-lg md:ml-auto mt-8 md:mt-10 xl:mt-6 2xl:mt-4 relative pl-6">
                        <div class="absolute left-0 top-1 bottom-0 w-[1px] bg-gradient-to-b from-[#ff3c00] to-transparent opacity-50 hero-text opacity-0 scale-y-0 origin-top line-anim"></div>
                        
                        <p class="text-[#ff3c00] uppercase text-[10px] md:text-xs tracking-widest font-bold mb-5 hero-text opacity-0">
                            A linha do conhecimento começa aqui e guia a sua jornada.
                        </p>
                        <p class="text-zinc-400 text-[1rem] md:text-[1.1rem] leading-relaxed font-light hero-text opacity-0">
                            Fundada em 2017, a <strong class="text-white font-normal">Editora Poisson</strong> publica livros acadêmicos e coletâneas multidisciplinares, distribuídos integralmente em acesso aberto. Cada título passa por curadoria editorial rigorosa, registro de <strong class="text-white font-normal">ISBN</strong>, <strong class="text-white font-normal">DOI</strong> e <strong class="text-white font-normal">ficha catalográfica</strong> — e fica disponível, sem barreiras, para qualquer leitor em qualquer lugar.
                        </p>
                    </div>
                </div>
            </section>

            <!-- PAINEL 02 -->
            <section class="panel panel-wide bg-white text-black">
                
                <div class="flex flex-col md:flex-row items-stretch justify-start gap-10 md:gap-[10vw] w-full h-full relative z-10 px-6 md:pl-[8vw]">
                    
                    <div class="flex flex-col h-auto md:h-full py-10 md:py-[12vh] w-full md:w-[50vw]">
                        <div class="flex-grow flex flex-col justify-center">
                            <h2 class="text-4xl md:text-5xl lg:text-[4.5vw] serif-extra leading-[1.1] tracking-tight text-black">
                                Volumes que <br> 
                                <span class="whitespace-nowrap"><span class="italic text-black transition-colors duration-500" id="text-reunem">reúnem</span> vozes</span> <br> 
                                em torno de <br> 
                                um tema.
                            </h2>
                        </div>
                        <div class="mt-8 md:mt-auto md:mb-[2vh]">
                            <p class="text-zinc-600 max-w-lg text-[0.95rem] md:text-[1.1rem] leading-relaxed">
                                Organizamos coletâneas científicas que agregam capítulos de autores diferentes em torno de uma área. Ideais para grupos de pesquisa, programas de pós-graduação, anais de eventos e dossiês temáticos.
                            </p>
                        </div>
                    </div>
                    
                    <div class="flex flex-col items-center justify-center w-full md:w-[40vw] pb-10 md:pb-0">
                        <h3 class="text-2xl md:text-4xl serif-extra italic mb-6 text-center text-black">Últimos Lançamentos</h3>
                        
                        <!-- Componente React Injetado Aqui -->
                        <div class="w-full">
                            <OrbitalCarousel client:load />
                        </div>
                        
                    </div>

                </div>
            </section>

            <!-- PAINEL 03 -->
            <section class="panel panel-wide" id="panel-areas">
                
                <div class="flex flex-col md:flex-row items-center justify-start gap-12 md:gap-[6vw] w-full h-full relative z-10 px-6 md:px-[6vw]">
                    
                    <!-- Coluna 1: Ttulo -->
                    <div class="w-full md:w-[35vw] flex flex-col justify-center shrink-0">
                        <h2 class="text-4xl md:text-5xl lg:text-[4.5vw] serif-extra leading-[1.1] tracking-tight text-white">
                            <div class="overflow-hidden" style="padding-bottom: 15px; margin-bottom: -15px;"><div class="area-title-line opacity-0">Publicamos</div></div>
                            <div class="overflow-hidden" style="padding-bottom: 15px; margin-bottom: -15px;"><div class="area-title-line opacity-0">das exatas às</div></div>
                            <div class="overflow-hidden" style="padding-bottom: 15px; margin-bottom: -15px;"><div class="area-title-line opacity-0">humanas,</div></div>
                            <div class="overflow-hidden" style="padding-bottom: 15px; margin-bottom: -15px;"><div class="area-title-line opacity-0"><span class="italic text-white transition-colors duration-200" id="text-todas-grandes">todas as grandes</span></div></div>
                            <div class="overflow-hidden" style="padding-bottom: 15px; margin-bottom: -15px;"><div class="area-title-line opacity-0">áreas.</div></div>
                        </h2>
                    </div>
                    
                    <!-- Coluna 2: Lista de reas -->
                    <div class="w-full md:w-[35vw] relative pl-6 md:pl-10 shrink-0">
                        <div class="absolute left-0 top-2 bottom-2 w-[1px] bg-zinc-800"></div>
                        <div class="absolute left-[-1px] top-2 w-[3px] h-16 bg-[#ff3c00] shadow-[0_0_12px_rgba(255,60,0,0.8)] rounded-full area-neon opacity-0"></div>

                        <div class="text-[0.9rem] md:text-[1.2rem] leading-[2.2] md:leading-[2.4] tracking-wide areas-blur-container" id="areas-list">
                            <span class="item" style="--i: 0">Ciências Exatas e da Terra</span>
                            <span class="separator" style="--i: 0">/</span>
                            <span class="item" style="--i: 1">Ciências Biológicas</span>
                            <span class="separator" style="--i: 1">/</span>
                            <span class="item" style="--i: 2">Engenharias</span>
                            <span class="separator" style="--i: 2">/</span>
                            <span class="item" style="--i: 3">Ciências da Saúde</span>
                            <span class="separator" style="--i: 3">/</span>
                            <span class="item" style="--i: 4">Ciências Agrárias</span>
                            <span class="separator" style="--i: 4">/</span>
                            <span class="item" style="--i: 5">Ciências Sociais Aplicadas</span>
                            <span class="separator" style="--i: 5">/</span>
                            <span class="item" style="--i: 6">Ciências Humanas</span>
                            <span class="separator" style="--i: 6">/</span>
                            <span class="item" style="--i: 7">Linguística, Letras e Artes</span>
                            <span class="separator" style="--i: 7">/</span>
                            <span class="item" style="--i: 8">Ciências e Humanidades para a Educação</span>
                        </div>
                    </div>

                    <!-- Coluna 3: Estatsticas -->
                    <div class="w-full md:w-[30vw] flex flex-col justify-center border-t md:border-t-0 md:border-l border-zinc-800/50 pt-10 md:pt-0 md:pl-[4vw] shrink-0">
                        <h3 class="text-2xl md:text-3xl serif-extra mb-8 md:mb-10 text-white stats-reveal opacity-0">Em números</h3>
                        
                        <div class="grid grid-cols-2 md:flex md:flex-col gap-6 md:gap-10">
                            <div class="stats-reveal opacity-0">
                                <div class="text-[8vw] md:text-[4vw] leading-none serif-extra bg-clip-text text-transparent bg-gradient-to-r from-cyan-300 to-purple-300 font-bold mb-2 count-number" data-target="1.200+">0</div>
                                <div class="text-[8px] md:text-[9px] text-zinc-500 uppercase tracking-[0.3em] font-bold">Títulos Publicados</div>
                            </div>
                            <div class="stats-reveal opacity-0">
                                <div class="text-[8vw] md:text-[4vw] leading-none serif-extra bg-clip-text text-transparent bg-gradient-to-r from-cyan-300 to-purple-300 font-bold mb-2 count-number" data-target="30.000+">0</div>
                                <div class="text-[8px] md:text-[9px] text-zinc-500 uppercase tracking-[0.3em] font-bold">Autores Ativos</div>
                            </div>
                            <div class="stats-reveal opacity-0">
                                <div class="text-[8vw] md:text-[4vw] leading-none serif-extra bg-clip-text text-transparent bg-gradient-to-r from-cyan-300 to-purple-300 font-bold mb-2 count-number" data-target="15">0</div>
                                <div class="text-[8px] md:text-[9px] text-zinc-500 uppercase tracking-[0.3em] font-bold">Países Atendidos</div>
                            </div>
                            <div class="stats-reveal opacity-0">
                                <div class="text-[8vw] md:text-[4vw] leading-none serif-extra bg-clip-text text-transparent bg-gradient-to-r from-cyan-300 to-purple-300 font-bold mb-2 count-number" data-target="10">0</div>
                                <div class="text-[8px] md:text-[9px] text-zinc-500 uppercase tracking-[0.3em] font-bold">Anos de História</div>
                            </div>
                        </div>
                    </div>

                </div>
            </section>

            <!-- PAINEL 04 -->
            <section class="panel bg-orange-600 text-white overflow-hidden" id="panel-transition">
                <div class="text-center relative z-10 w-full max-w-[90vw] md:max-w-[70vw]">
                    <h2 class="font-bold tracking-tighter leading-[0.8] mb-8 flex flex-col items-center uppercase">
                        <div class="w-full flex justify-between text-[15vw] md:text-[12vw]" id="line-mergulhe">
                            <span>M</span><span>E</span><span>R</span><span>G</span><span>U</span><span>L</span><span>H</span><span>E</span>
                        </div>
                        <div class="w-full flex justify-between text-[10vw] md:text-[8vw] mt-2" id="line-dna">
                            <span>N</span><span>O</span>
                            <span class="nosso-text">N</span><span class="nosso-text">O</span><span class="nosso-text">S</span><span class="nosso-text">S</span><span class="nosso-text">O</span>
                            <span class="dna-text">D</span><span class="dna-text">N</span><span class="dna-text">A</span>
                        </div>
                    </h2>
                    <p class="uppercase tracking-[0.4em] text-[20px] md:text-[32px] font-bold opacity-70 mt-12 wave-text">Publicações que conectam saberes</p>
                </div>
                <div class="absolute top-1/2 left-1/2 -mt-[10vw] -ml-[10vw] w-[20vw] h-[20vw] bg-black rounded-full scale-0" id="transition-circle"></div>
            </section>

        </div>
    </div>

    <!-- PARTE 2: SCROLL VERTICAL -->
    <div class="vertical-content">
        <svg class="absolute top-0 left-0 w-full h-full pointer-events-none" id="vertical-vine-svg" style="overflow:visible; z-index:200;">
            <defs>
                <linearGradient id="v-vine-grad" x1="0" y1="0" x2="0" y2="1">
                    <stop id="vine-stop-1" offset="0%" stop-color="#ffffff" />
                    <stop id="vine-stop-2" offset="5%" stop-color="#ffffff" />
                    <stop id="vine-stop-3" offset="25%" stop-color="#ff3c00" />
                    <stop id="vine-stop-4" offset="100%" stop-color="#ff3c00" />
                </linearGradient>
                <filter id="hand-drawn-v" x="-5%" y="-5%" width="110%" height="110%">
                    <feTurbulence type="turbulence" baseFrequency="0.008 0.015" numOctaves="2" seed="3" result="noise"/>
                    <feDisplacementMap in="SourceGraphic" in2="noise" scale="1.5" xChannelSelector="R" yChannelSelector="G"/>
                </filter>
            </defs>
            <path id="v-vine" class="thread-path" d="" style="stroke: url(#v-vine-grad);" />
            <path id="v-vine-reverse" class="thread-path" d="" style="stroke: url(#v-vine-grad); display:none;" />
            <circle id="v-transition-node" class="node" cx="0" cy="0" r="10" style="display:none;" />
            <g id="v-arrow-tip" style="display:none;">
                <path d="M -55,-13 L 0,0 L -55,13" fill="none" stroke="#ff3c00" stroke-width="8" stroke-linecap="round" stroke-linejoin="round" id="vine-arrow-path"/>
            </g>
        </svg>
        
        <!-- SEÇÃO DNA DA EDITORA -->
        <section class="min-h-screen py-20 md:py-40 px-6 md:px-10 bg-black text-white relative z-10 overflow-hidden" id="section-dna-details">
            <div class="max-w-6xl mx-auto">
                <div class="flex flex-col md:flex-row gap-12 md:gap-20 items-start justify-between">
                    
                    <!-- Coluna da Esquerda: Efeito Particle Assemble -->
                    <div class="w-full md:w-5/12" id="sticky-canvas-container">
                        <canvas id="particleCanvas" width="700" height="400" class="w-full h-auto max-w-full"></canvas>
                    </div>

                    <!-- Coluna da Direita: Blocos de Conteúdo -->
                    <div class="w-full md:w-6/12 space-y-24 md:mt-10">
                        
                        <!-- Bloco 1 -->
                        <div class="dna-block opacity-0 translate-y-10 transition-all duration-700 ease-out">
                            <span class="text-[#00b0ff] font-mono text-sm">01 / ACERVO LIVRE</span>
                            <h3 class="text-2xl md:text-3xl font-bold mt-2 mb-4 text-white">Conhecimento sem Barreiras</h3>
                            <p class="text-zinc-400 text-[0.95rem] md:text-[1.1rem] leading-relaxed font-light">
                                Todo o nosso acervo é disponibilizado <strong class="text-white font-normal">gratuitamente</strong>. Acreditamos que a ciência não deve ter barreiras. Ao publicar conosco, sua pesquisa fica disponível para milhões de leitores, pesquisadores e estudantes em todo o mundo, ampliando o impacto real do seu trabalho.
                            </p>
                        </div>

                        <!-- Bloco 2 -->
                        <div class="dna-block opacity-0 translate-y-10 transition-all duration-700 ease-out" id="block-curriculo">
                            <span class="text-[#ff3c00] font-mono text-sm">02 / VALORIZAÇÃO</span>
                            <h3 class="text-2xl md:text-3xl font-bold mt-2 mb-4 text-white">Destaque no Currículo</h3>
                            <p class="text-zinc-400 text-[0.95rem] md:text-[1.1rem] leading-relaxed font-light">
                                Uma publicação na Editora Poisson agrega valor imediato ao seu <strong class="text-white font-normal">Curriculum Lattes</strong>. Nossas obras contam com conselho editorial rigoroso, registro de <strong class="text-white font-normal">ISBN</strong> e <strong class="text-white font-normal">DOI</strong>, garantindo a pontuação e o prestígio necessários para sua progressão acadêmica.
                            </p>
                        </div>

                        <!-- Bloco 3 -->
                        <div class="dna-block opacity-0 translate-y-10 transition-all duration-700 ease-out" id="block-mercado">
                            <span class="text-[#00b0ff] font-mono text-sm">03 / MERCADO</span>
                            <h3 class="text-2xl md:text-3xl font-bold mt-2 mb-4 text-white">Autoridade e Prestígio</h3>
                            <p class="text-zinc-400 text-[0.95rem] md:text-[1.1rem] leading-relaxed font-light">
                                Além do meio acadêmico, o mercado valoriza profissionais que produzem conhecimento. Tornar-se autor de um livro ou capítulo consolida sua autoridade, abrindo portas para consultorias, palestras e liderança em sua área de atuação.
                            </p>
                        </div>

                    </div>
                </div>
            </div>
        </section>

        <!-- SEÇÃO: BUSCA INTELIGENTE COM IA -->
        <section class="min-h-screen py-20 md:py-40 px-6 md:px-10 bg-black text-white relative z-10 overflow-hidden" id="section-ai-search">
            
            <div class="max-w-6xl mx-auto relative z-10">
                <div class="flex flex-col md:flex-row-reverse gap-16 md:gap-24 items-center justify-between">
                    
                    <!-- Coluna da Direita (Originalmente Esquerda): Conteúdo Editorial -->
                    <div class="w-full md:w-5/12">
                        <span class="uppercase tracking-widest text-[10px] md:text-xs font-bold" id="ai-subtitle" style="color: #ffffff;">Tecnologia & Descoberta</span>
                        <h2 class="text-5xl md:text-[5vw] serif-extra italic mt-4 leading-none text-white">A busca que entende você.</h2>
                        <p class="text-zinc-400 mt-8 text-lg leading-relaxed font-light">
                            Nosso ecossistema utiliza <span id="ai-highlight-1" style="color:#7c3aed;" class="font-normal">inteligência artificial</span> para mapear relações semânticas profundas entre as obras. Não buscamos apenas termos; compreendemos o contexto da sua pesquisa.
                        </p>
                        
                        <div class="mt-12 space-y-12">
                            <!-- Item 1 -->
                            <div class="flex gap-6 items-start">
                                <div class="w-1 bg-[#7c3aed] h-12 flex-shrink-0"></div>
                                <div>
                                    <h3 class="text-xl font-bold text-white">Busca Semântica Avançada</h3>
                                    <p class="text-zinc-500 text-lg mt-2 leading-relaxed font-light">Esqueça as palavras-chave rígidas. Nossa IA entende sinônimos, contextos e conceitos complexos, conectando você a referências que outros sistemas ignoram.</p>
                                </div>
                            </div>

                            <!-- Item 2 -->
                            <div class="flex gap-6 items-start">
                                <div class="w-1 bg-[#7c3aed] h-12 flex-shrink-0"></div>
                                <div>
                                    <h3 class="text-xl font-bold text-white">Alavancagem de Citações</h3>
                                    <p class="text-zinc-500 text-lg mt-2 leading-relaxed font-light">Para os autores, isso significa visibilidade máxima. Sua obra é recomendada ativamente para pesquisadores do mundo todo, impulsionando seu <strong id="ai-highlight-2" style="color:#7c3aed;" class="font-normal">índice de citações</strong>.</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Coluna da Esquerda: A Lupa Investigativa -->
                    <div class="w-full md:w-6/12 flex justify-center items-center relative h-[400px]" id="magnifier-container">
                        
                        <!-- Texto de Fundo (Normal/Pequeno) -->
                        <div class="absolute inset-0 flex items-center justify-center p-8">
                            <p class="text-zinc-700 text-sm md:text-base leading-relaxed font-light text-justify opacity-30">
                                A busca por conhecimento exige precisão. Cada verbete, cada citação e cada referência cruzada formam uma teia invisível de saberes. Nossa inteligência artificial vasculha essa malha, identificando padrões que olhos humanos poderiam ignorar, revelando a verdadeira relevância de cada pesquisa acadêmica publicada em nosso catálogo.
                            </p>
                        </div>

                        <!-- Texto Ampliado (Revelado pela Lupa) -->
                        <div class="absolute inset-0 flex items-center justify-center p-8 pointer-events-none" id="magnifier-lens" style="clip-path: circle(54px at 50% 50%);">
                            <p class="text-[#7c3aed] text-xl md:text-2xl leading-relaxed font-bold text-justify">
                                A busca por conhecimento exige precisão. Cada verbete, cada citação e cada referência cruzada formam uma teia invisível de saberes. Nossa inteligência artificial vasculha essa malha, identificando padrões que olhos humanos poderiam ignorar, revelando a verdadeira relevância de cada pesquisa acadêmica publicada em nosso catálogo.
                            </p>
                        </div>

                        <!-- cone da Lupa (Perfeitamente Centrado e Desenhado em SVG) -->
                        <div class="absolute w-[180px] h-[180px] pointer-events-none" id="magnifier-glass" style="top: 50%; left: 50%; transform: translate(-50%, -50%);">
                            <svg viewBox="0 0 100 100" fill="none" stroke="#7c3aed" stroke-linecap="round" class="w-full h-full filter drop-shadow-[0_0_15px_rgba(124,58,237,0.4)]">
                                <circle cx="50" cy="50" r="30" stroke-width="3" />
                                <circle cx="50" cy="50" r="27" stroke-width="1" opacity="0.5" stroke-dasharray="2 2" />
                                <line x1="71.21" y1="71.21" x2="95" y2="95" stroke-width="5" />
                                <line x1="78.28" y1="78.28" x2="88.89" y2="88.89" stroke="#0a0a0a" stroke-width="2" />
                            </svg>
                        </div>

