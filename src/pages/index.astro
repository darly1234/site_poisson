                        <div class="flex-shrink-0 w-14 h-14 md:w-[72px] md:h-[72px] rounded-full border border-[#facc15] flex items-center justify-center bg-black relative z-10" style="box-shadow: 0 0 20px rgba(250,204,21,0.3);">
                            <span class="text-[#facc15] font-mono font-bold text-lg md:text-2xl">05</span>
