---
import '../styles/global.css';
import '../styles/home.css';
import Header from '../components/Header.astro';
import { OrbitalCarousel } from '../components/OrbitalCarousel';
import SiteFooter from '../components/SiteFooter.astro';
import versionData from '../data/version.json';

const version = versionData.version;

let popupImageUrl: string | null = null;
try {
  const r = await fetch('https://individual.poisson.com.br/api/public/popup');
  if (r.ok) {
    const p = await r.json();
    if (p?.enabled && p?.content?.imageUrl) popupImageUrl = p.content.imageUrl;
  }
} catch {}

function parseAutoresSSG(raw: string | null | undefined): string {
  if (!raw) return 'Editora Poisson';
  try {
    const arr = JSON.parse(raw);
    if (Array.isArray(arr) && arr.length > 0) {
      const first = arr[0];
      const name = typeof first === 'string' ? first : (first?.nome ?? first?.name ?? first?.autor ?? String(first));
      return arr.length === 1 ? name : `${name} et al.`;
    }
  } catch { /* not JSON */ }
  return String(raw).split(',')[0].trim();
}
let carouselBooks: any[] = [];
try {
  const r2 = await fetch('https://individual.poisson.com.br/api/public/livros/all');
  if (r2.ok) {
    const data: any[] = await r2.json();
    carouselBooks = data
      .filter((b: any) => b.capa)
      .slice(0, 9)
      .map((b: any) => ({
        id: b.id,
        title: b.titulo ?? 'Sem título',
        author: parseAutoresSSG(b.autores),
        cover: b.capa,
        excerpt: (b.resumo ?? '').replace(/&nbsp;/g, ' ').replace(/\s+/g, ' ').trim().substring(0, 200),
        href: `https://editorapoisson.com.br/biblioteca/?id=${encodeURIComponent(b.id)}`,
      }));
  }
} catch {}
const firstCoverUrl: string | null = carouselBooks[0]?.cover ?? null;
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <script is:inline>
      localStorage.removeItem('theme');
      document.documentElement.setAttribute('data-theme','dark');
    </script>
    <style is:global>
      #theme-toggle-btn, #theme-toggle-btn-mobile { display: none !important; }
      .page-content .v-panel {
        width: 100%;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 5vh 4vw;
        position: relative;
        overflow: hidden;
      }
      @media (min-width: 768px) {
        .page-content .v-panel { padding: 5vw; }
      }
      .carousel-container {
        transition: transform 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      }
      .video-card {
        transition: all 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      }
      /* Sliders Customizados de Vídeo */
      .video-controls input[type="range"].timeline-slider {
        margin: 0;
        padding: 0;
        width: 100%;
        min-width: 0;
      }
      .video-controls input[type="range"].timeline-slider::-webkit-slider-runnable-track {
        background: #3f3f46; /* zinc-700 */
        height: 4px;
        border-radius: 9999px;
      }
      .video-controls input[type="range"].timeline-slider::-webkit-slider-thumb {
        background: #ff3c00;
        height: 10px;
        width: 10px;
        border-radius: 9999px;
        margin-top: -3px;
        cursor: pointer;
        appearance: none;
      }
      .video-controls input[type="range"].timeline-slider::-moz-range-track {
        background: #3f3f46;
        height: 4px;
        border-radius: 9999px;
      }
      .video-controls input[type="range"].timeline-slider::-moz-range-thumb {
        background: #ff3c00;
        height: 10px;
        width: 10px;
        border-radius: 9999px;
        border: none;
        cursor: pointer;
      }
      /* Animação e Estilo do Slider de Volume Vertical */
      .volume-capsule input[type="range"].volume-slider {
        -webkit-appearance: slider-vertical;
        writing-mode: bt-lr;
        width: 6px;
        height: 64px;
        background: #27272a;
        border-radius: 9999px;
        outline: none;
        cursor: pointer;
      }
      .volume-capsule input[type="range"].volume-slider::-webkit-slider-runnable-track {
        background: #27272a;
        width: 6px;
        border-radius: 9999px;
      }
      .volume-capsule input[type="range"].volume-slider::-webkit-slider-thumb {
        appearance: none;
        -webkit-appearance: none;
        background: #ff3c00;
        height: 12px;
        width: 12px;
        border-radius: 50%;
        margin-left: -3px;
        border: none;
        box-shadow: 0 0 8px rgba(255, 60, 0, 0.6);
      }
      .volume-capsule input[type="range"].volume-slider::-moz-range-track {
        background: #27272a;
        width: 6px;
        border-radius: 9999px;
      }
      .volume-capsule input[type="range"].volume-slider::-moz-range-thumb {
        background: #ff3c00;
        height: 12px;
        width: 12px;
        border-radius: 50%;
        border: none;
        box-shadow: 0 0 8px rgba(255, 60, 0, 0.6);
      }
      @keyframes horiz-bounce {
        0%, 100% { transform: translateX(0); }
        50% { transform: translateX(4px); }
      }
      .animate-horizontal-bounce {
        display: inline-block;
        animation: horiz-bounce 1s infinite;
      }
    </style>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editora Poisson | O Conhecimento em Movimento</title>
    <meta name="description" content="Editora Poisson — mais de 1.200 títulos científicos em acesso aberto, com ISBN, DOI e ficha catalográfica. Publique sua pesquisa com a gente.">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    {popupImageUrl && <link rel="preload" as="image" href={popupImageUrl} fetchpriority="high" />}
    {firstCoverUrl && <link rel="preload" as="image" href={firstCoverUrl} fetchpriority="high" />}
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200;300;400;700&family=Playfair+Display:ital,wght@0,900;1,900&family=DM+Serif+Display:ital@0;1&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200;300;400;700&family=Playfair+Display:ital,wght@0,900;1,900&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet"></noscript>
</head>
<body>

    <Header />

    <!-- WRAPPER ÚNICO: vine SVG + todas as seções em scroll vertical -->
    <div class="page-content" style="position: relative; overflow-x: hidden;">

        <!-- FIO DE OURO — SVG vertical cobrindo a página toda -->
        <svg class="absolute top-0 left-0 w-full h-full pointer-events-none" id="vertical-vine-svg" style="overflow:visible; z-index:200;">
            <defs>
                <linearGradient id="v-vine-grad" x1="0" y1="0" x2="0" y2="1">
                    <stop id="vine-stop-1" offset="0%" stop-color="#ffffff" />
                    <stop id="vine-stop-2" offset="5%" stop-color="#ffffff" />
                    <stop id="vine-stop-3" offset="25%" stop-color="#ff3c00" />
                    <stop id="vine-stop-4" offset="100%" stop-color="#ff3c00" />
                </linearGradient>
                <filter id="hand-drawn-v" x="-5%" y="-5%" width="110%" height="110%">
                    <feTurbulence type="turbulence" baseFrequency="0.008 0.015" numOctaves="2" seed="3" result="noise"/>
                    <feDisplacementMap in="SourceGraphic" in2="noise" scale="1.5" xChannelSelector="R" yChannelSelector="G"/>
                </filter>
            </defs>
            <path id="v-vine" class="thread-path" d="" style="stroke: url(#v-vine-grad);" />
            <path id="v-vine-reverse" class="thread-path" d="" style="stroke: url(#v-vine-grad); display:none;" />
            <circle id="v-transition-node" class="node" cx="0" cy="0" r="10" style="display:none;" />
            <g id="v-arrow-tip" style="display:none;">
                <path d="M -55,-13 L 0,0 L -55,13" fill="none" stroke="#ff3c00" stroke-width="8" stroke-linecap="round" stroke-linejoin="round" id="vine-arrow-path"/>
            </g>
        </svg>

        <!-- SEÇÃO 01: HERO -->
        <section class="v-panel bg-black text-white">
            <div class="w-full relative z-10">
                <h1 class="text-5xl md:text-[10vw] serif-extra leading-none mb-4 mt-[14vh] md:mt-[16vh] xl:mt-[10vh] 2xl:mt-[8vh]" id="premium-title">
                    <div class="line-wrap"><span class="kinetic-text">A</span></div>
                    <div class="line-wrap"><span class="kinetic-text">CIÊNCIA</span></div>
                    <br>
                    <div class="heartbeat-pulse mt-2">
                        <div class="line-wrap">
                            <span class="kinetic-text italic text-zinc-400/50">É VIVA</span>
                        </div>
                    </div>
                </h1>
                <div class="max-w-lg md:ml-auto mt-8 md:mt-10 xl:mt-6 2xl:mt-4 relative pl-6">
                    <div class="absolute left-0 top-1 bottom-0 w-[1px] bg-gradient-to-b from-[#ff3c00] to-transparent opacity-50 hero-text opacity-0 scale-y-0 origin-top line-anim"></div>
                    <p class="text-[#ff3c00] uppercase text-[10px] md:text-xs tracking-widest font-bold mb-5 hero-text opacity-0">
                        A linha do conhecimento começa aqui e guia a sua jornada.
                    </p>
                    <p class="text-zinc-400 text-[1rem] md:text-[1.1rem] leading-relaxed font-light hero-text opacity-0">
                        Fundada em 2017, a <strong class="text-white font-normal">Editora Poisson</strong> publica livros acadêmicos e coletâneas multidisciplinares, distribuídos integralmente em acesso aberto. Cada título passa por curadoria editorial rigorosa, registro de <strong class="text-white font-normal">ISBN</strong>, <strong class="text-white font-normal">DOI</strong> e <strong class="text-white font-normal">ficha catalográfica</strong> — e fica disponível, sem barreiras, para qualquer leitor em qualquer lugar.
                    </p>
                </div>
            </div>
        </section>

        <!-- SEÇÃO 02: VOLUMES / CAROUSEL -->
        <section class="v-panel bg-white text-black">
            <div class="flex flex-col md:flex-row items-center justify-center gap-10 md:gap-16 w-full relative z-10">
                <div class="flex flex-col justify-between py-10 w-full md:w-[45%]">
                    <h2 class="text-4xl md:text-5xl lg:text-[4.5vw] serif-extra leading-[1.1] tracking-tight text-black">
                        Volumes que <br>
                        <span class="whitespace-nowrap"><span class="italic text-black transition-colors duration-500" id="text-reunem">reúnem</span> vozes</span> <br>
                        em torno de <br>
                        um tema.
                    </h2>
                    <div class="mt-8 md:mt-12">
                        <p class="text-zinc-600 max-w-lg text-[0.95rem] md:text-[1.1rem] leading-relaxed">
                            Organizamos coletâneas científicas que agregam capítulos de autores diferentes em torno de uma área. Ideais para grupos de pesquisa, programas de pós-graduação, anais de eventos e dossiês temáticos.
                        </p>
                    </div>
                </div>
                <div class="flex flex-col items-center justify-center w-full md:w-[45%]">
                    <h3 class="text-2xl md:text-4xl serif-extra italic mb-6 text-center text-black">Últimos Lançamentos</h3>
                    <div class="w-full">
                        <OrbitalCarousel client:load books={carouselBooks} />
                    </div>
                </div>
            </div>
        </section>

        <!-- SEÇÃO 03: ÁREAS DO CONHECIMENTO -->
        <section class="v-panel bg-black text-white" id="panel-areas">
            <div class="flex flex-col md:flex-row items-start md:items-center justify-center gap-12 md:gap-10 w-full relative z-10">

                <!-- Coluna 1: Título -->
                <div class="w-full md:w-[30%] flex flex-col justify-center shrink-0">
                    <h2 class="text-4xl md:text-5xl lg:text-[4vw] serif-extra leading-[1.1] tracking-tight text-white">
                        <div class="overflow-hidden" style="padding-bottom:15px;margin-bottom:-15px;"><div class="area-title-line opacity-0">Publicamos</div></div>
                        <div class="overflow-hidden" style="padding-bottom:15px;margin-bottom:-15px;"><div class="area-title-line opacity-0">das exatas às</div></div>
                        <div class="overflow-hidden" style="padding-bottom:15px;margin-bottom:-15px;"><div class="area-title-line opacity-0">humanas,</div></div>
                        <div class="overflow-hidden" style="padding-bottom:15px;margin-bottom:-15px;"><div class="area-title-line opacity-0"><span class="italic text-white transition-colors duration-200" id="text-todas-grandes">todas as grandes</span></div></div>
                        <div class="overflow-hidden" style="padding-bottom:15px;margin-bottom:-15px;"><div class="area-title-line opacity-0">áreas.</div></div>
                    </h2>
                </div>

                <!-- Coluna 2: Lista de Áreas -->
                <div class="w-full md:w-[38%] relative pl-6 md:pl-10 shrink-0">
                    <div class="absolute left-0 top-2 bottom-2 w-[1px] bg-zinc-800"></div>
                    <div class="absolute left-[-1px] top-2 w-[3px] h-16 bg-[#ff3c00] shadow-[0_0_12px_rgba(255,60,0,0.8)] rounded-full area-neon opacity-0"></div>
                    <div class="text-[0.9rem] md:text-[1.2rem] leading-[2.2] md:leading-[2.4] tracking-wide areas-blur-container" id="areas-list">
                        <span class="item" style="--i: 0">Ciências Exatas e da Terra</span>
                        <span class="separator" style="--i: 0">/</span>
                        <span class="item" style="--i: 1">Ciências Biológicas</span>
                        <span class="separator" style="--i: 1">/</span>
                        <span class="item" style="--i: 2">Engenharias</span>
                        <span class="separator" style="--i: 2">/</span>
                        <span class="item" style="--i: 3">Ciências da Saúde</span>
                        <span class="separator" style="--i: 3">/</span>
                        <span class="item" style="--i: 4">Ciências Agrárias</span>
                        <span class="separator" style="--i: 4">/</span>
                        <span class="item" style="--i: 5">Ciências Sociais Aplicadas</span>
                        <span class="separator" style="--i: 5">/</span>
                        <span class="item" style="--i: 6">Ciências Humanas</span>
                        <span class="separator" style="--i: 6">/</span>
                        <span class="item" style="--i: 7">Linguística, Letras e Artes</span>
                        <span class="separator" style="--i: 7">/</span>
                        <span class="item" style="--i: 8">Ciências e Humanidades para a Educação</span>
                    </div>
                </div>

                <!-- Coluna 3: Estatísticas -->
                <div class="w-full md:w-[28%] flex flex-col justify-center border-t md:border-t-0 md:border-l border-zinc-800/50 pt-10 md:pt-0 md:pl-8 shrink-0">
                    <h3 class="text-2xl md:text-3xl serif-extra mb-8 md:mb-10 text-white stats-reveal opacity-0">Em números</h3>
                    <div class="grid grid-cols-2 md:flex md:flex-col gap-6 md:gap-10">
                        <div class="stats-reveal opacity-0">
                            <div class="text-[8vw] md:text-[3.5vw] leading-none serif-extra bg-clip-text text-transparent bg-gradient-to-r from-cyan-300 to-purple-300 font-bold mb-2 count-number" data-target="1.200+">0</div>
                            <div class="text-[8px] md:text-[9px] text-zinc-500 uppercase tracking-[0.3em] font-bold">Títulos Publicados</div>
                        </div>
                        <div class="stats-reveal opacity-0">
                            <div class="text-[8vw] md:text-[3.5vw] leading-none serif-extra bg-clip-text text-transparent bg-gradient-to-r from-cyan-300 to-purple-300 font-bold mb-2 count-number" data-target="30.000+">0</div>
                            <div class="text-[8px] md:text-[9px] text-zinc-500 uppercase tracking-[0.3em] font-bold">Autores Ativos</div>
                        </div>
                        <div class="stats-reveal opacity-0">
                            <div class="text-[8vw] md:text-[3.5vw] leading-none serif-extra bg-clip-text text-transparent bg-gradient-to-r from-cyan-300 to-purple-300 font-bold mb-2 count-number" data-target="15">0</div>
                            <div class="text-[8px] md:text-[9px] text-zinc-500 uppercase tracking-[0.3em] font-bold">Países Atendidos</div>
                        </div>
                        <div class="stats-reveal opacity-0">
                            <div class="text-[8vw] md:text-[3.5vw] leading-none serif-extra bg-clip-text text-transparent bg-gradient-to-r from-cyan-300 to-purple-300 font-bold mb-2 count-number" data-target="10">0</div>
                            <div class="text-[8px] md:text-[9px] text-zinc-500 uppercase tracking-[0.3em] font-bold">Anos de História</div>
                        </div>
                    </div>
                </div>

            </div>
        </section>

        <!-- SEÇÃO 04: MERGULHE NO NOSSO DNA -->
        <section class="v-panel bg-orange-600 text-white" id="panel-transition">
            <div class="text-center relative z-10 w-full max-w-[90vw] md:max-w-[70vw]">
                <h2 class="font-bold tracking-tighter leading-[0.8] mb-8 flex flex-col items-center uppercase">
                    <div class="w-full flex justify-between text-[15vw] md:text-[12vw]" id="line-mergulhe">
                        <span>M</span><span>E</span><span>R</span><span>G</span><span>U</span><span>L</span><span>H</span><span>E</span>
                    </div>
                    <div class="w-full flex justify-between text-[10vw] md:text-[8vw] mt-2" id="line-dna">
                        <span>N</span><span>O</span>
                        <span class="nosso-text">N</span><span class="nosso-text">O</span><span class="nosso-text">S</span><span class="nosso-text">S</span><span class="nosso-text">O</span>
                        <span class="dna-text">D</span><span class="dna-text">N</span><span class="dna-text">A</span>
                    </div>
                </h2>
                <p class="uppercase tracking-[0.4em] text-[20px] md:text-[32px] font-bold opacity-70 mt-12 wave-text">Publicações que conectam saberes</p>
            </div>
            <div class="absolute top-1/2 left-1/2 -mt-[10vw] -ml-[10vw] w-[20vw] h-[20vw] bg-black rounded-full scale-0" id="transition-circle"></div>
        </section>

        <!-- SEÇÃO DNA DA EDITORA -->
        <section class="min-h-screen py-10 md:py-40 px-6 md:px-10 bg-white text-zinc-900 relative z-10 overflow-hidden" id="section-dna-details">
            <div class="max-w-6xl mx-auto">
                <div class="flex flex-col md:flex-row gap-12 md:gap-20 items-start justify-between">
                    <div class="w-full md:w-5/12" id="sticky-canvas-container">
                        <canvas id="particleCanvas" width="700" height="400" class="w-full h-auto max-w-full"></canvas>
                    </div>
                    <div class="w-full md:w-6/12 space-y-24 md:mt-10">
                        <div class="dna-block opacity-0 translate-y-10 transition-all duration-700 ease-out">
                            <span class="text-[#0066cc] font-mono text-sm">01 / ACERVO LIVRE</span>
                            <h3 class="text-2xl md:text-3xl font-bold mt-2 mb-4 text-zinc-900">Conhecimento sem <span class="orange-word" style="transition:color 0.3s">Barreiras</span></h3>
                            <p class="text-zinc-600 text-[0.95rem] md:text-[1.1rem] leading-relaxed font-light">Todo o nosso acervo é disponibilizado <strong class="text-zinc-900 font-semibold">gratuitamente</strong>. Acreditamos que a ciência não deve ter barreiras. Ao publicar conosco, sua pesquisa fica disponível para millions de leitores, pesquisadores e estudantes em todo o mundo, ampliando o impacto real do seu trabalho.</p>
                        </div>
                        <div class="dna-block opacity-0 translate-y-10 transition-all duration-700 ease-out" id="block-curriculo">
                            <span class="text-[#ff3c00] font-mono text-sm">02 / VALORIZAÇÃO</span>
                            <h3 class="text-2xl md:text-3xl font-bold mt-2 mb-4 text-zinc-900">Destaque no Currículo</h3>
                            <p class="text-zinc-600 text-[0.95rem] md:text-[1.1rem] leading-relaxed font-light">Uma publicação na Editora Poisson agrega valor imediato ao seu <strong class="text-zinc-900 font-semibold">Curriculum Lattes</strong>. Nossas obras contam com conselho editorial rigoroso, registro de <strong class="text-zinc-900 font-semibold">ISBN</strong> e <strong class="text-zinc-900 font-semibold">DOI</strong>, garantindo a pontuação e o prestígio necessários para sua progressão acadêmica.</p>
                        </div>
                        <div class="dna-block opacity-0 translate-y-10 transition-all duration-700 ease-out" id="block-mercado">
                            <span class="text-[#0066cc] font-mono text-sm">03 / MERCADO</span>
                            <h3 class="text-2xl md:text-3xl font-bold mt-2 mb-4 text-zinc-900">Autoridade e Prestígio</h3>
                            <p class="text-zinc-600 text-[0.95rem] md:text-[1.1rem] leading-relaxed font-light">Além do meio acadêmico, o mercado valoriza profissionais que produzem conhecimento. Tornar-se autor de um livro ou capítulo consolida sua autoridade, abrindo portas para consultorias, palestras e liderança em sua área de atuação.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- SEÇÃO: DEPOIMENTOS -->
        <section class="v-panel bg-black text-white py-12 px-6 md:px-10 relative z-10 overflow-hidden flex flex-col items-center justify-center" id="section-testimonials">
            <!-- Glow background effects -->
            <div class="absolute -top-40 -left-40 w-96 h-96 bg-[#ff3c00]/10 rounded-full blur-[100px] pointer-events-none"></div>
            <div class="absolute -bottom-40 -right-40 w-96 h-96 bg-[#7c3aed]/10 rounded-full blur-[100px] pointer-events-none"></div>

            <div class="max-w-4xl w-full flex flex-col items-center mb-8">
                <span class="text-[#ff3c00] uppercase tracking-widest text-[10px] md:text-xs font-bold mb-3 text-center">Relatos de quem publica</span>
                <h2 class="text-6xl md:text-8xl serif-extra italic font-bold mt-4 leading-none text-white text-center">Depoimentos</h2>
            </div>

            <!-- Galeria de 3 Vídeos de Depoimentos -->
            <div class="relative w-full max-w-5xl flex flex-col items-center mt-8 md:mt-14 z-10 px-2">

                <!-- Faixa de cards + navegação -->
                <div class="flex items-center justify-center gap-2 md:gap-5 w-full">

                    <!-- Botão Anterior -->
                    <button id="btnPrevVideo" class="flex-shrink-0 w-9 h-9 md:w-11 md:h-11 bg-zinc-900/90 hover:bg-zinc-950 rounded-full border-2 border-zinc-700 hover:border-[#ff3c00] hover:shadow-[0_0_15px_rgba(255,60,0,0.2)] flex items-center justify-center cursor-pointer transition-all duration-300 z-20 active:scale-95" aria-label="Vídeo anterior">
                        <svg class="w-4 h-4 md:w-5 md:h-5 text-zinc-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                        </svg>
                    </button>

                    <!-- Card Lateral Esquerdo -->
                    <div id="card-gallery-left" class="flex-shrink-0 w-20 h-14 md:w-44 md:h-28 bg-zinc-900 rounded-xl border border-zinc-800/60 overflow-hidden opacity-40 cursor-pointer hover:opacity-60 transition-all duration-500 select-none">
                        <video id="video-gallery-left" loop playsinline muted class="w-full h-full object-cover object-center pointer-events-none"></video>
