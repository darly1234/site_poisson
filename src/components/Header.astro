---
import versionData from '../data/version.json';
const version = versionData.version;
const pathname = Astro.url.pathname;
const isHome = pathname === '/' || pathname === '' || pathname === '/index.html';
const navBgClass = 'bg-black border-b border-zinc-800';

// Helper to determine if a nav link is active
function isActive(href: string): boolean {
  if (href === '/') return isHome;
  return pathname.startsWith(href);
}
---
<script is:inline>
  (function() {
    const fixed = document.documentElement.getAttribute('data-fixed-theme');
    const theme = fixed || localStorage.getItem('theme') || 'dark';
    document.documentElement.setAttribute('data-theme', theme);
  })();
</script>

