---
import ChamadasAbertas from './library/ChamadasAbertas';
---

<ChamadasAbertas client:load />

<footer class="site-footer">
  <div class="site-footer__inner">

    <div class="site-footer__brand">
      <div class="site-footer__brand-row">
        <!-- Logo animada — mesma animação GSAP do header, IDs únicos sf-* -->
        <div id="sf-logo-container" class="sf-logo" aria-hidden="true">
          <svg id="sf-logo-svg" viewBox="0 0 600 600" class="sf-logo__svg" style="overflow: visible;" xmlns="http://www.w3.org/2000/svg">
            <polygon id="sf-logo-ripple"       points="300,130.29 469.71,300 300,469.71 130.29,300" fill="none" stroke="#159A41" stroke-width="6" style="opacity:0; transform-origin:300px 300px;" />
            <polygon id="sf-logo-left-green"   points="175,208.08 266.92,300 175,391.92 83.08,300"  fill="#159A41" style="transform-origin:175px 300px;" />
            <polygon id="sf-logo-right-green"  points="425,208.08 516.92,300 425,391.92 333.08,300" fill="#159A41" style="transform-origin:425px 300px;" />
            <polygon id="sf-logo-center-blue"  points="300,130.29 469.71,300 300,469.71 130.29,300" fill="#1F3D7E" style="transform-origin:300px 300px;" />
          </svg>
        </div>
        <span class="site-footer__name">Editora Poisson</span>
      </div>
      <span class="site-footer__cnpj">CNPJ 08.642.675/0001-46</span>
    </div>

    <nav class="site-footer__links" aria-label="Contato">
      <a href="https://wa.me/553182185531" target="_blank" rel="noopener noreferrer" class="site-footer__link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        (31) 8218-5531
      </a>
      <a href="mailto:contato@poisson.com.br" class="site-footer__link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <path d="M2 8l10 7 10-7"/>
        </svg>
        contato@poisson.com.br
      </a>
      <a href="https://instagram.com/editorapoisson" target="_blank" rel="noopener noreferrer" class="site-footer__link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5"/>
          <circle cx="12" cy="12" r="5"/>
          <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
        </svg>
        @editorapoisson
      </a>
      <a href="https://facebook.com/Editorapoisson" target="_blank" rel="noopener noreferrer" class="site-footer__link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
        </svg>
        facebook.com/Editorapoisson
      </a>
    </nav>

    <p class="site-footer__copy">
      &copy; {new Date().getFullYear()} Editora Poisson. Todos os direitos reservados.
    </p>
  </div>
</footer>

<script is:inline>
(function () {
  function runFooterLogoAnim() {
    var DURATION = 6;
    var tl = gsap.timeline({ repeat: -1 });

    tl.set("#sf-logo-left-green, #sf-logo-right-green, #sf-logo-center-blue, #sf-logo-ripple, #sf-logo-container", {
      x: 0, y: 0, scale: 1, rotation: 0, opacity: 1
    });

    tl.fromTo("#sf-logo-left-green",
      { x: -700, y: -500, rotation: 220, opacity: 0 },
      { x: 0, y: 0, rotation: 0, opacity: 1, duration: 1.2, ease: "back.out(1.70158)" },
      0.05
    );

    tl.fromTo("#sf-logo-right-green",
      { x: 700, y: -500, rotation: -220, opacity: 0 },
      { x: 0, y: 0, rotation: 0, opacity: 1, duration: 1.2, ease: "back.out(1.70158)" },
      0.20
    );

    tl.fromTo("#sf-logo-center-blue",
      { y: -800, rotation: -180, opacity: 0 },
      { y: 0, rotation: 0, opacity: 1, duration: 1.2, ease: "back.out(1.70158)" },
      0.35
    );

    tl.fromTo("#sf-logo-ripple",
      { scale: 1, opacity: 0.6 },
      { scale: 1.45, opacity: 0, duration: 0.7, ease: "none" },
      1.55
    );

    tl.to("#sf-logo-container", { scale: 1.012, duration: 0.96, ease: "sine.out" }, 1.55)
      .to("#sf-logo-container", { scale: 0.988, duration: 1.92, ease: "sine.inOut" })
      .to("#sf-logo-container", { scale: 1,     duration: 0.96, ease: "sine.in"   });

    tl.to("#sf-logo-container", { opacity: 0, duration: 0.55, ease: "power2.in" }, 5.45);
  }

  function initFooterLogo() {
    if (typeof gsap !== 'undefined') {
      runFooterLogoAnim();
    } else {
      var s = document.createElement('script');
      s.src = 'https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js';
      s.onload = runFooterLogoAnim;
      document.head.appendChild(s);
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFooterLogo);
  } else {
    initFooterLogo();
  }
})();
</script>

<style is:global>
  .sf-logo {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .sf-logo__svg { width: 36px; height: 36px; }

  .site-footer {
    background: #0b0f19;
    border-top: 1px solid rgba(255,255,255,0.07);
    padding: 3rem 1.5rem 2rem;
    font-family: 'Plus Jakarta Sans', sans-serif;
    color: #f8fafc;
  }
  .site-footer__inner {
    max-width: 72rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    text-align: center;
  }
  .site-footer__brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
  }
  .site-footer__brand-row {
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }
  .site-footer__name {
    font-size: 1.125rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: #f8fafc;
  }
  .site-footer__cnpj {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    color: rgba(255,255,255,0.35);
    text-transform: uppercase;
  }
  .site-footer__links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 2rem;
    justify-content: center;
    align-items: center;
  }
  .site-footer__link {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.8rem;
    color: rgba(255,255,255,0.55);
    text-decoration: none;
    transition: color 0.2s ease;
    letter-spacing: 0.02em;
  }
  .site-footer__link:hover { color: #f97316; }
  .site-footer__copy {
    font-size: 0.72rem;
    color: rgba(255,255,255,0.25);
    letter-spacing: 0.05em;
    margin: 0;
  }
</style>
