---
// ThemeToggle.astro
---
<button id="theme-toggle-btn" class="fixed top-[105px] right-6 md:right-10 z-[150] p-3 rounded-full border border-white/10 glass text-white/70 hover:text-white hover:border-white/20 transition-all duration-300 shadow-xl flex items-center justify-center" aria-label="Alternar tema">
  <!-- Sun Icon (shows in dark theme) -->
  <svg id="theme-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M22 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
  <!-- Moon Icon (shows in light theme) -->
  <svg id="theme-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
</button>

<script is:inline>
  (function() {
    const btn = document.getElementById('theme-toggle-btn');
    const sun = document.getElementById('theme-sun');
    const moon = document.getElementById('theme-moon');

    if (!btn || !sun || !moon) return;

    const pageDefault = document.documentElement.getAttribute('data-default-theme') || 'dark';
    let theme = localStorage.getItem('theme') || pageDefault;
    document.documentElement.setAttribute('data-theme', theme);
    updateTheme(theme);

    function updateTheme(t) {
      document.documentElement.setAttribute('data-theme', t);
      if (t === 'light') {
        sun.classList.add('hidden');
        moon.classList.remove('hidden');
        btn.classList.add('light-btn');
      } else {
        sun.classList.remove('hidden');
        moon.classList.add('hidden');
        btn.classList.remove('light-btn');
      }
    }

    btn.addEventListener('click', () => {
      const currentTheme = document.documentElement.getAttribute('data-theme') || 'dark';
      const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
      localStorage.setItem('theme', newTheme);
      updateTheme(newTheme);
    });
  })();
</script>

<style>
  .glass {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
  }
  #theme-toggle-btn.light-btn {
    background: rgba(0, 0, 0, 0.05);
    border-color: rgba(0, 0, 0, 0.15);
    color: rgba(0, 0, 0, 0.7);
  }
  #theme-toggle-btn.light-btn:hover {
    color: rgba(0, 0, 0, 1);
    border-color: rgba(0, 0, 0, 0.3);
  }
</style>
